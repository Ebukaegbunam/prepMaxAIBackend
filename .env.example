# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development                  # development | staging | production
APP_VERSION=1.0.0
PORT=8000
LOG_LEVEL=INFO

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT secret from Supabase dashboard → Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Database (asyncpg URL for SQLAlchemy) ─────────────────────────────────────
# Supabase Transaction Pooler: postgresql+asyncpg://postgres.ref:password@host:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/prepai

# ── LLM providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── External services ─────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=AIza...

# ── Security ──────────────────────────────────────────────────────────────────
ADMIN_TOKEN=your-secret-admin-token
INTERNAL_TOKEN=your-secret-internal-token   # used by Railway cron jobs

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BUCKET=prepai-photos

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_HOURS=24

# ── AI cost cap ───────────────────────────────────────────────────────────────
AI_COST_CAP_USD=5.0

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
